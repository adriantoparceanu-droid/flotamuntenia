################################################################
# Template .env pentru productie pe cPanel shared.
# Copiaza acest fisier ca `.env` pe server si completeaza valorile.
#
# IMPORTANT:
#   - APP_DEBUG=false in productie (intotdeauna)
#   - APP_KEY se genereaza pe server cu: php artisan key:generate
#   - Parolele SMTP / Oblio NU merg aici — se cripteaza in DB
#     (tabelele setari_smtp / facturare_setari) — vezi CLAUDE.md §10
################################################################

APP_NAME=FlotaMuntenia
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Europe/Bucharest
APP_URL=https://app.flotamuntenia.ro

APP_LOCALE=ro
APP_FALLBACK_LOCALE=ro
APP_FAKER_LOCALE=ro_RO

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# Logging — pe cPanel rotam pe zi pentru a evita fisiere uriase
LOG_CHANNEL=daily
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

################################################################
# Baza de date — MySQL pe cPanel
# Completeaza dupa ce creezi DB-ul in cPanel > MySQL Databases.
# Numele DB / user pe cPanel sunt de obicei prefixate cu username-ul cPanel
# (ex: USER_flotamuntenia, USER_flotaadmin).
################################################################
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# Sesiuni si cache — pe cPanel shared mergem pe DB (fara Redis)
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=flotamuntenia

################################################################
# Mail — NU folosi MAIL_* pentru SMTP-uri reale!
# Conform CLAUDE.md §10, credentialele SMTP merg criptate in DB
# (tabelul `setari_smtp`) si se configureaza din UI.
# Lasam aici doar fallback-ul pentru notificari de framework.
################################################################
MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@flotamuntenia.ro"
MAIL_FROM_NAME="${APP_NAME}"

################################################################
# Google Maps — cheia este publica (frontend);
# RESTRICTIONEAZ-O in Cloud Console pe HTTP referrer:
#   https://app.flotamuntenia.ro/*
################################################################
GOOGLE_MAPS_API_KEY=

VITE_APP_NAME="${APP_NAME}"

################################################################
# Bootstrap admin — pentru PRIMUL deploy automat prin .cpanel.yml.
# Comanda `php artisan app:bootstrap-admin` (din .cpanel.yml)
# creeaza un cont admin DACA aceste variabile sunt setate
# si DACA inca nu exista admin cu acel email.
#
# DUPA primul deploy reusit:
#   1. Logheaza-te cu credentialele de mai jos
#   2. Schimba-ti parola din profil
#   3. STERGE aceste 3 linii din .env de pe server
#   4. Redeploy ("Deploy HEAD Commit" in Git Version Control)
################################################################
# INITIAL_ADMIN_EMAIL=
# INITIAL_ADMIN_PASSWORD=
# INITIAL_ADMIN_NAME="Administrator"
